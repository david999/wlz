# ===== 迭代 1 配置示例 =====
# 复制为 .env 并按需修改。切勿把真实密钥提交到版本库。
#
# 说明:迭代 1 只做只读行情监控,只用公共 WebSocket/REST 接口,
#       不需要 API 密钥即可运行。如填写密钥,请仅授予【只读】权限,
#       严禁开启提现权限。

# 交易所 id(ccxt 命名):okx / bybit / binance ...
ARB_EXCHANGE=okx

# 是否使用测试网 / 模拟盘(强烈建议 true)
ARB_TESTNET=true

# 可选:只读 API 密钥(不填则仅用公共行情)
ARB_API_KEY=
ARB_API_SECRET=
# OKX 需要 passphrase;其他交易所留空
ARB_API_PASSWORD=

# SQLite 落库路径(本地运行用此值;Docker 部署由 docker-compose.yml 固化为
# /app/data/arb.db 以持久化到卷,容器内此处设置不生效)
ARB_DB_PATH=arb.db

# 交易对与阈值配置文件
ARB_SYMBOLS_PATH=arb/config/symbols.yaml

# 日志级别:DEBUG / INFO / WARNING
ARB_LOG_LEVEL=INFO

# 价差评估间隔(秒)
ARB_EVAL_INTERVAL_SEC=1.0

# 资金费率刷新间隔(秒)
ARB_FUNDING_REFRESH_SEC=60.0

# ===== 运行模式(monitor / backtest / synthesize / paper / live / cross) =====
# 命令行 --mode 优先;此处为缺省模式
ARB_MODE=monitor

# ===== 策略(z-score 均值回归,迭代 2+) =====
ARB_ZSCORE_WINDOW=200
ARB_ENTRY_Z=2.0
ARB_EXIT_Z=0.5

# ===== 执行(迭代 3 paper / 迭代 4 live) =====
ARB_SLIPPAGE_BPS=2.0          # 模拟撮合滑点
ARB_ORDER_TIMEOUT_SEC=5.0     # 限价单超时撤单

# ===== 风控(迭代 3+) =====
ARB_MAX_POSITION_NOTIONAL=1000.0
ARB_MAX_DELTA_BPS=50.0
ARB_MAX_DRAWDOWN_PCT=5.0

# ===== 资金管理(迭代 5) =====
ARB_TOTAL_CAPITAL=20000.0
ARB_LEVERAGE=2.0
ARB_MARGIN_ALERT_RATIO=0.5

# ===== 安全开关:live 真实下单必须显式置 true =====
ARB_ALLOW_LIVE=false

# ===== 半自动逐单确认(仅约束开仓;平仓与 kill switch 仍全自动) =====
# true 时开仓前先告警并进入"待确认",人工在 Telegram 回复 confirm 后才下单;
# 超时未确认则作废该机会。默认 false 保持全自动(向后兼容)。
ARB_REQUIRE_MANUAL_CONFIRM=false
# 待确认超时(秒),超时未确认则作废
ARB_CONFIRM_TIMEOUT_SEC=300.0

# ===== 告警(Telegram,可选;留空则不发送) =====
ARB_TELEGRAM_TOKEN=
ARB_TELEGRAM_CHAT_ID=

# ===== 回测(迭代 2) =====
ARB_BACKTEST_SOURCE=db        # db | csv
ARB_BACKTEST_CSV_PATH=
ARB_BACKTEST_PAIR=            # 留空=第一个 pair

# ===== 历史样本合成(synthesize 模式,迭代 4a;供回测/标定) =====
# 用 ccxt 拉现货+永续历史 K 线合成 (ts_ms, net_bps) 并导出 CSV;需联网与 ccxt。
ARB_HISTORY_TIMEFRAME=1h      # K 线周期:1m/5m/15m/1h/4h/1d ...
ARB_HISTORY_LIMIT=500         # 每腿拉取的 K 线根数上限
ARB_HISTORY_FUNDING_BPS=0.0   # 合成时叠加的方向化资金费(bps)
ARB_HISTORY_OUT_CSV=history_samples.csv  # 输出 CSV 路径(与 load_from_csv 兼容)
