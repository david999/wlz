# ===== 迭代 1 配置示例 =====
# 复制为 .env 并按需修改。切勿把真实密钥提交到版本库。
#
# 说明:迭代 1 只做只读行情监控,只用公共 WebSocket/REST 接口,
#       不需要 API 密钥即可运行。如填写密钥,请仅授予【只读】权限,
#       严禁开启提现权限。

# 交易所 id(ccxt 命名):okx / bybit / binance ...
ARB_EXCHANGE=okx

# 是否使用测试网 / 模拟盘(强烈建议 true)
ARB_TESTNET=true

# 可选:只读 API 密钥(不填则仅用公共行情)
ARB_API_KEY=
ARB_API_SECRET=
# OKX 需要 passphrase;其他交易所留空
ARB_API_PASSWORD=

# SQLite 落库路径
ARB_DB_PATH=arb.db

# 交易对与阈值配置文件
ARB_SYMBOLS_PATH=arb/config/symbols.yaml

# 日志级别:DEBUG / INFO / WARNING
ARB_LOG_LEVEL=INFO

# 价差评估间隔(秒)
ARB_EVAL_INTERVAL_SEC=1.0

# 资金费率刷新间隔(秒)
ARB_FUNDING_REFRESH_SEC=60.0

# ===== 运行模式(monitor / backtest / paper / live / cross) =====
# 命令行 --mode 优先;此处为缺省模式
ARB_MODE=monitor

# ===== 策略(z-score 均值回归,迭代 2+) =====
ARB_ZSCORE_WINDOW=200
ARB_ENTRY_Z=2.0
ARB_EXIT_Z=0.5

# ===== 执行(迭代 3 paper / 迭代 4 live) =====
ARB_SLIPPAGE_BPS=2.0          # 模拟撮合滑点
ARB_ORDER_TIMEOUT_SEC=5.0     # 限价单超时撤单

# ===== 风控(迭代 3+) =====
ARB_MAX_POSITION_NOTIONAL=1000.0
ARB_MAX_DELTA_BPS=50.0
ARB_MAX_DRAWDOWN_PCT=5.0

# ===== 资金管理(迭代 5) =====
ARB_TOTAL_CAPITAL=20000.0
ARB_LEVERAGE=2.0
ARB_MARGIN_ALERT_RATIO=0.5

# ===== 安全开关:live 真实下单必须显式置 true =====
ARB_ALLOW_LIVE=false

# ===== 告警(Telegram,可选;留空则不发送) =====
ARB_TELEGRAM_TOKEN=
ARB_TELEGRAM_CHAT_ID=

# ===== 回测(迭代 2) =====
ARB_BACKTEST_SOURCE=db        # db | csv
ARB_BACKTEST_CSV_PATH=
ARB_BACKTEST_PAIR=            # 留空=第一个 pair
